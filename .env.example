# Copy this file to .env and fill in your real values.
# .env is gitignored and must never be committed.

# --- Firebase (used by chatbot + desktop app) ---
FIREBASE_API_KEY=your_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.firebasedatabase.app
FIREBASE_PROJECT_ID=your_project
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# --- OpenAI (only for chatbot/intentsgenerator.py) ---
OPENAI_API_KEY=sk-...

# --- ESP32 (better kept in an untracked secrets.h, not committed) ---
WIFI_SSID=your_wifi
WIFI_PASSWORD=your_wifi_password
